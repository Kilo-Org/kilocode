{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Devil",
  "identifier": "ai.kilo.desktop.dev",
  "mainBinaryName": "Devil",
  "version": "../package.json",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* ws://localhost:* https://api.devil.ai https://app.devil.ai https://us.i.posthog.com https://github.com https://models.dev https://ingest.devilsessions.ai; img-src 'self' data: https:; font-src 'self'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "icon": [
      "icons/dev/32x32.png",
      "icons/dev/128x128.png",
      "icons/dev/128x128@2x.png",
      "icons/dev/icon.icns",
      "icons/dev/icon.ico"
    ],
    "active": true,
    "targets": ["deb", "rpm", "dmg", "nsis", "app"],
    "externalBin": ["sidecars/kilo-cli"],
    "linux": {
      "rpm": {
        "compression": {
          "type": "none"
        }
      }
    },
    "macOS": {
      "entitlements": "./entitlements.plist"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/dev/icon.ico",
        "headerImage": "assets/nsis-header.bmp",
        "sidebarImage": "assets/nsis-sidebar.bmp"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["opencode"]
      }
    }
  }
}
