# Enforce LF line endings for all text files
* text=auto eol=lf

# Git LFS tracking for binary/media files
*.gif filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text

# Visual regression baseline snapshots
packages/devil-ui/tests/**/*.png filter=lfs diff=lfs merge=lfs -text
packages/devil-vscode/tests/**/*.png filter=lfs diff=lfs merge=lfs -text

# Hide non-English localization files by default in GitHub PR diffs.
**/i18n/*.ts linguist-generated=true
**/i18n/en.ts linguist-generated=false
**/i18n/en*.ts linguist-generated=false
**/i18n/package-nls-en.ts linguist-generated=false
**/i18n/index.ts linguist-generated=false
**/i18n/parity.test.ts linguist-generated=false
packages/devil-i18n/src/*.ts linguist-generated=true
packages/devil-i18n/src/en.ts linguist-generated=false

# Auto-generated CLI reference docs
packages/devil-docs/markdoc/partials/cli-commands-table.md linguist-generated=true
packages/devil-docs/pages/code-with-ai/platforms/cli-reference.md linguist-generated=true
