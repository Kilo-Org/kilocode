# 云服务器部署 — 复制为 .env 后修改
# 文档：docs/enterprise/PHASE1-DEPLOY-CLOUD.md

# 强密码（与 VS Code remoteServer.password 一致）
KILO_SERVER_PASSWORD=change-me-use-long-random-string
KILO_ENGINE_IMAGE=kilo-engine:local

# 云安全：Engine/Bridge/Qdrant/License 仅本机监听；开发者只访问 APISIX
KILO_ENGINE_BIND=127.0.0.1:4096
QDRANT_BIND=127.0.0.1:6333
BRIDGE_BIND=127.0.0.1:8080
LICENSE_MOCK_BIND=127.0.0.1:19090

# 对公网开放（安全组只需放行此端口 + 可选 SSH 22）
APISIX_HTTP_BIND=0.0.0.0:9080

# 模型 API：同机 vLLM 用 docker 服务名；外部模型填公网/内网 URL
KILO_CUSTOM_API_BASE_URL=http://vllm:8000/v1
KILO_CUSTOM_API_KEY=

# GPU 推理（需 nvidia-container-toolkit）
# VLLM_BIND=127.0.0.1:8000
# VLLM_MODEL=Qwen/Qwen2.5-Coder-14B-Instruct

# 兼容旧变量名（未设置 BIND 时仍可用）
# KILO_ENGINE_PORT=4096
