# Copy to .env and adjust

KILO_SERVER_PASSWORD=change-me-in-production
KILO_ENGINE_PORT=4096
KILO_ENGINE_IMAGE=kilo-engine:local

KILO_CUSTOM_API_BASE_URL=http://host.docker.internal:8000/v1
KILO_CUSTOM_API_KEY=

QDRANT_PORT=6333

# Optional vLLM profile: docker compose --profile vllm up -d
VLLM_PORT=8000
VLLM_MODEL=Qwen/Qwen2.5-Coder-14B-Instruct

# Optional gateway: docker compose --profile gateway up -d
APISIX_HTTP_PORT=9080

# Optional license mock: docker compose --profile license up -d
LICENSE_MOCK_PORT=19090
