// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "VSCode - Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--disable-extensions", "--extensionDevelopmentPath=${workspaceFolder}/packages/kilo-vscode"],
      "outFiles": ["${workspaceFolder}/packages/kilo-vscode/dist/**/*.js"],
      "preLaunchTask": "VSCode - Compile"
    },
    {
      "name": "VSCode - Run Extension (Local Backend)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--disable-extensions", "--extensionDevelopmentPath=${workspaceFolder}/packages/kilo-vscode"],
      "outFiles": ["${workspaceFolder}/packages/kilo-vscode/dist/**/*.js"],
      "preLaunchTask": "VSCode - Compile",
      "env": {
        "KILO_API_URL": "http://localhost:3000",
        "LLMAPI_API_URL": "http://localhost:8081",
        "LLMAPI_BASE_URL": "http://localhost:4001/v1"
      }
    },
    {
      "name": "VSCode - Run Extension (All Features)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--disable-extensions", "--extensionDevelopmentPath=${workspaceFolder}/packages/kilo-vscode"],
      "outFiles": ["${workspaceFolder}/packages/kilo-vscode/dist/**/*.js"],
      "preLaunchTask": "VSCode - Compile",
      "env": {
        "KILOCODE_FEATURE_AGENT_MANAGER": "true",
        "KILOCODE_FEATURE_KILOCLAW": "true",
        "KILOCODE_FEATURE_MARKETPLACE": "true",
        "KILOCODE_FEATURE_WORKTREE": "true"
      }
    }
  ]
}
